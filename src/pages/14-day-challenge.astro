---
/**
 * The 14-Day Baseline Reset Challenge — Edition 2
 * Based on: workshop template
 * URL: /14-day-challenge
 */
import LeadLayout from '@/layouts/LeadLayout.astro';
import LeadCaptureForm from '@/components/forms/LeadCaptureForm.tsx';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Dialog from '@/components/ui/overlay/Dialog/Dialog.astro';
import { Hero } from '@/components/hero';

const formTags = ['website_lead', 'baseline_challenge_ed2'];
const workoutVideoId = 'M1T-91viaKU';
const welcomeVideoId = '90vV35qGOPk';

const termsHtml = `<p>By registering, I agree to receive communications. Unsubscribe anytime.</p>`;
---

<LeadLayout
  title="The 14-Day Baseline Reset — Edition 2 | Effective Outcomes"
  description="Three workouts a week. 25 minutes each. No equipment. Built for Luxembourg financial services professionals. April 20–May 3, 2026."
>

  <!-- ── Hero ── -->
  <Hero layout="centered" size="md" showGrid>
    <Badge slot="badge" variant="brand" pill>
      Edition 2 &bull; April 20, 2026
    </Badge>

    <h1 slot="title">
      Q1 is over.<br />
      Your body took the hit.
    </h1>

    <p slot="description" class="text-foreground">
      Two weeks. Three 25-minute workouts. No equipment.<br />
      Built for a calendar that never empties.
    </p>

    <div slot="actions">
      <Button size="lg" data-open-dialog="challenge-dialog">
        Register now &mdash; Early bird &euro;147
      </Button>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-foreground mt-5">
      <span class="flex items-center gap-1.5">
        <Icon name="check-circle" size="xs" class="text-brand-300" />
        No equipment
      </span>
      <span class="flex items-center gap-1.5">
        <Icon name="check-circle" size="xs" class="text-brand-300" />
        25 min per session
      </span>
      <span class="flex items-center gap-1.5">
        <Icon name="check-circle" size="xs" class="text-brand-300" />
        15 participants
      </span>
    </div>
  </Hero>

  <!-- ── Editorial ── -->
  <section class="pt-8 pb-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-3xl px-6">

      <!-- Lead paragraph -->
      <div class="border-l-4 border-brand-300 pl-6 my-8">
        <p class="text-xl font-semibold text-foreground leading-relaxed">
          Audit season does not end when Q1 closes.
        </p>
        <p class="text-foreground mt-2">
          The board pack still lands on Tuesday. The CSSF deadline still moves to Friday.
          Your calendar never empties. That is the point.
        </p>
      </div>

      <!-- ── SECTION 2: PROOF ── -->
      <div class="prose max-w-none prose-invert">
        <h2>What happened in Edition 1 — March 2026</h2>
      </div>

      <div class="my-6 space-y-4">

        <!-- Proof A: Delphine -->
        <Card variant="default" padding="lg">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-full bg-secondary flex items-center justify-center text-xs font-semibold text-foreground-muted shrink-0">D</div>
            <div>
              <p class="text-sm font-semibold text-foreground">Delphine</p>
              <p class="text-xs text-foreground-muted">Senior Manager, Risk &amp; Internal Audit — Big Four Luxembourg</p>
            </div>
          </div>
          <!-- Step 1: gauges -->
          <div class="space-y-2.5">
            {[
              { label: 'Before workout', pct: 50, val: '5/10' },
              { label: 'After workout',  pct: 90, val: '9/10' },
              { label: 'End of day',     pct: 70, val: '7/10' },
            ].map(({ label, pct, val }) => (
              <div class="flex items-center gap-3">
                <span class="text-xs text-foreground-muted w-24 shrink-0">{label}</span>
                <div class="flex-1 h-1.5 bg-border rounded-full overflow-hidden">
                  <div class="h-full bg-brand-300 rounded-full" style={`width: ${pct}%`}></div>
                </div>
                <span class="text-xs font-semibold text-foreground w-8 text-right shrink-0">{val}</span>
              </div>
            ))}
          </div>
          <!-- Step 2: screenshot -->
          <img src="/images/Screenshot Delphine 2026-03-31 at 10.25.34.png" alt="Delphine's Day 3 check-in" class="mt-4 w-full rounded-lg" />
          <p class="text-xs text-foreground-muted mt-3">Day 3 community check-in · Skool · 14-Day Reset Challenge</p>
        </Card>

        <!-- Proof B: Roland's Garmin (anonymous on page) -->
        <Card variant="default" padding="lg">
          <!-- Step 1: watch face -->
          <div class="flex items-center gap-4 mb-4">
            <div class="w-16 h-16 rounded-full flex flex-col items-center justify-center shrink-0" style="background: #080f1a; border: 2px solid #1e3a60;">
              <span class="font-display text-xl font-bold leading-none" style="color: #4fc3f7;">50</span>
              <span class="text-[7px] mt-0.5 tracking-wide uppercase" style="color: #6baed6;">fitness age</span>
            </div>
            <p class="text-sm text-foreground leading-relaxed">Day 3. The Garmin showed a different number.</p>
          </div>
          <!-- Step 2: screenshot -->
          <img src="/images/Screenshot Roland - 2026-03-30 at 15.16.33.png" alt="Day 3 community check-in" class="w-full rounded-lg" />
        </Card>

        <!-- Proof C: Maxime -->
        <Card variant="default" padding="lg">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-full bg-secondary flex items-center justify-center text-xs font-semibold text-foreground-muted shrink-0">MB</div>
            <div>
              <p class="text-sm font-semibold text-foreground">Maxime</p>
              <p class="text-xs text-foreground-muted">Chief Compliance Officer</p>
            </div>
          </div>
          <blockquote class="border-l-2 border-brand-300 pl-4 text-foreground-muted italic text-sm leading-relaxed mb-4">
            "It held up under a real working week. This structure is a game changer."
          </blockquote>
          <img src="/images/Screenshot Maxime 2026-03-31 at 10.27.11.png" alt="Maxime LinkedIn recommendation" class="w-full rounded-lg" />
          <p class="text-xs text-foreground-muted mt-3">LinkedIn recommendation</p>
        </Card>

      </div>

      <!-- ── SECTION 3: WHAT IT IS ── -->
      <div class="border-l-4 border-brand-300 pl-6 mt-12 mb-6">
        <p class="text-xl font-semibold text-foreground leading-relaxed">
          What the 14 days look like
        </p>
      </div>

      <div class="my-4">
        <span class="inline-flex items-center gap-2 bg-brand-300/10 border border-brand-300/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wider uppercase text-brand-300">
          No equipment. No gym. No excuses.
        </span>
      </div>

      <p class="text-base text-foreground leading-relaxed mt-4">
        Three workouts a week. 25 minutes each, filmed and waiting in the community before your first meeting.
      </p>

      <!-- YouTube workout video -->
      <div class="my-6 rounded-xl overflow-hidden border border-border bg-secondary aspect-video shadow-lg">
        <iframe
          src={`https://www.youtube.com/embed/${workoutVideoId}?rel=0`}
          title="25-minute workout — follow along from home or a hotel room"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full"
          loading="lazy"
        />
      </div>

      <p class="text-base text-foreground leading-relaxed mt-4">
        Every hour during the workday: 10 to 20 squats or two flights of stairs. Nothing that requires you to change or leave your desk.
      </p>

      <!-- Client office squats video -->
      <div class="my-6 rounded-xl overflow-hidden border border-border bg-secondary shadow-lg">
        <video
          src="/images/laurent squatting copy.mp4"
          controls
          playsinline
          preload="metadata"
          class="w-full"
        >
          Your browser does not support video playback.
        </video>
      </div>

      <p class="text-base text-foreground leading-relaxed mt-4">
        The goal is not transformation in 14 days. The goal is to find out whether the routine holds when the board pack lands on Tuesday and the CSSF deadline moves to Friday.
      </p>

      <p class="text-base text-foreground leading-relaxed mt-4">
        You are not doing this on your own. There is a group of people in the same situation checking in every day.
      </p>

      <!-- Community screenshot -->
      <img src="/images/Screenshot community 2026-03-31 at 11.56.08.png" alt="Community check-ins Week 2" class="my-6 w-full rounded-xl border border-border shadow-lg" />


      <!-- Registration details -->
      <div class="prose max-w-none mt-12">
        <h2>Registration</h2>
      </div>

      <Card class="my-6" padding="lg">
        <div class="space-y-3 text-foreground [&>p]:mb-0">
          <p><strong>Dates:</strong> April 20 – May 3, 2026</p>
          <p><strong>Kickoff call:</strong> Sunday April 20</p>
          <p><strong>Investment:</strong> <strong>&euro;147</strong> early bird</p>
          <p><strong>Group size:</strong> 15 participants</p>
          <p><strong>Format:</strong> Daily community check-ins on Skool, three 25-min workouts per week</p>
        </div>
      </Card>

      <!-- Alvin bio -->
      <div class="flex gap-4 items-start py-8 border-t border-border mt-8">
        <!-- REPLACE: swap initials div for your headshot:
             <img src="/images/alvin.jpg" alt="Alvin Sicre" class="w-12 h-12 rounded-full object-cover shrink-0"> -->
        <div class="w-12 h-12 rounded-full bg-secondary flex items-center justify-center text-sm font-semibold text-foreground-muted shrink-0">AS</div>
        <div>
          <p class="text-sm font-bold text-foreground">Alvin Sicre</p>
          <p class="mt-1 text-sm text-foreground leading-relaxed">
            18 years in Luxembourg financial services. Head of Compliance and Conducting Officer at EQT Partners, Aberdeen Standard, KPMG London. I left the industry in 2024 to build what had always kept me functional under pressure: a movement system that survives a real work week.
          </p>
        </div>
      </div>

      <!-- Final CTA -->
      <div class="final-cta text-center border-t border-border pt-10 mt-4">
        <p class="text-2xl font-bold text-foreground font-display tracking-tight">Registration closes April 18.</p>
        <p class="text-lg text-foreground-muted mt-2">Everyone starts on Day 1.</p>
        <div class="mt-6">
          <Button size="lg" data-open-dialog="challenge-dialog">Register now &mdash; &euro;147</Button>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Registration Dialog ── -->
  <Dialog id="challenge-dialog" title="Register — Edition 2" size="md">
    <div class="mb-4 p-4 rounded-lg bg-secondary text-sm text-foreground-muted">
      April 20 – May 3 &nbsp;&bull;&nbsp; Kickoff April 20 &nbsp;&bull;&nbsp; 15 spots &nbsp;&bull;&nbsp; Early bird &euro;147
    </div>
    <LeadCaptureForm
      client:load
      formTags={formTags}
      submitLabel="Secure my spot"
      defaultCountry="LU"
      successRedirect="/challenge-confirmed"
      termsHtml={termsHtml}
    />
  </Dialog>

  <!-- ── Floating CTA Bar ── -->
  <div class="floating-cta" id="floating-cta">
    <div class="container flex items-center justify-center gap-6">
      <p class="hidden md:block text-sm text-foreground-muted mb-0">
        April 20 &bull; 15 spots &bull; Early bird &euro;147
      </p>
      <Button variant="primary" size="lg" data-open-dialog="challenge-dialog" class="whitespace-nowrap w-full md:w-auto text-center">
        Register now &mdash; Early bird &euro;147
      </Button>
    </div>
  </div>

</LeadLayout>

<style>
  .floating-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 1rem 0;
    background: oklch(from var(--background) l c h / 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--border);
    transform: translateY(150%);
    transition: transform 0.3s ease;
  }
  .floating-cta.visible {
    transform: translateY(0);
  }
  @media (max-width: 640px) {
    :global(#challenge-dialog [data-dialog-panel]) {
      max-width: 100% !important;
      border-radius: 0;
      min-height: 100vh;
      max-height: none;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-open-dialog]').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const id = el.getAttribute('data-open-dialog');
      if (id && (window as any).openDialog) (window as any).openDialog(id);
    });
  });

  const floatingCta = document.getElementById('floating-cta');
  if (floatingCta) {
    const showThreshold = window.innerWidth < 768 ? 450 : 768;
    let visible = false;
    function update() {
      const scrollY = window.scrollY;
      const finalCta = document.querySelector('.final-cta');
      const docHeight = document.documentElement.scrollHeight;
      const nearBottom = scrollY + window.innerHeight > docHeight - 200;
      let hideNearFinal = false;
      if (finalCta) {
        const rect = finalCta.getBoundingClientRect();
        hideNearFinal = rect.top < window.innerHeight + 200;
      }
      if (scrollY > showThreshold && !nearBottom && !hideNearFinal) {
        if (!visible) { floatingCta.classList.add('visible'); visible = true; }
      } else {
        if (visible) { floatingCta.classList.remove('visible'); visible = false; }
      }
    }
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
