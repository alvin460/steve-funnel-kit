---
/**
 * Challenge Registration Confirmation
 * URL: /challenge-confirmed
 */
import LeadLayout from '@/layouts/LeadLayout.astro';
import { Hero } from '@/components/hero';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

const welcomeVideoId = '90vV35qGOPk';
---

<LeadLayout
  title="You're in — Edition 2 | Effective Outcomes"
  description="You are registered for the 14-Day Baseline Reset, Edition 2."
>

  <Hero layout="centered" size="md">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="check" size="xs" />
      Registration confirmed
    </Badge>

    <h1 slot="title">You are in.</h1>

    <p slot="description">
      Edition 2 starts April 20. You will receive an email shortly with your Skool community link.
    </p>
  </Hero>

  <section class="py-[var(--space-section-md)] bg-background">
    <div class="mx-auto max-w-2xl px-6">

      <div class="border-l-4 border-brand-300 pl-6 my-8">
        <p class="text-xl font-semibold text-foreground leading-relaxed">
          Check your inbox.
        </p>
        <p class="text-foreground-muted mt-2">
          Your Skool invite is on its way.
        </p>
      </div>

      <!-- Alvin welcome video -->
      <div class="rounded-xl overflow-hidden border border-border bg-secondary aspect-video shadow-lg">
        <iframe
          src={`https://www.youtube.com/embed/${welcomeVideoId}?rel=0`}
          title="Welcome from Alvin — what to expect inside the community"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="w-full h-full"
          loading="lazy"
        />
      </div>
      <p class="mt-3 text-center text-xs text-foreground-muted">
        A short welcome from Alvin — what to expect in the community.
      </p>

    </div>
  </section>

</LeadLayout>
