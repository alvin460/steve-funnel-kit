---
/**
 * Homepage — Funnel Landing Page
 * "Make $" themed placeholder copy. Replace with your client's brand and offer.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Hero from '@/components/hero/Hero.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
---

<BaseLayout
  title="Turn Every Click Into Revenue"
  description="AI-powered funnels that capture, nurture, and convert leads automatically. Stop leaving money on the table."
  includeOrgSchema
>
  <Header
    slot="header"
    shape="floating"
    position="fixed"
    size="lg"
    variant="transparent"
    colorScheme="invert"
    scrollReveal
    showCta
    cta={{ label: 'Get Started', href: '#get-started' }}
  />

  {/* ================================================================
      HERO — Dark section with ambient glow
      ================================================================ */}
  <div class="invert-section">
    <Hero layout="centered" size="xl" showGrid>
      <Badge slot="badge" variant="brand" pill>
        <span class="flex items-center gap-1.5">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-400"></span>
          </span>
          Now accepting early access
        </span>
      </Badge>

      <h1 slot="title">Turn Every Click<br class="hidden sm:inline" /> Into Revenue</h1>

      <p slot="description">
        Stop burning ad spend on pages that don't convert. Our AI-powered funnel system
        captures, qualifies, and closes leads automatically — so every dollar you spend
        comes back multiplied.
      </p>

      <div slot="actions">
        <Button size="lg" href="#get-started">Start Free</Button>
        <Button size="lg" variant="secondary" href="#features">See How It Works</Button>
      </div>

      {/* Stats row */}
      <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto">
        <div class="text-center">
          <p class="text-2xl font-bold text-foreground font-mono">$12M+</p>
          <p class="text-sm text-foreground-muted mt-1">Revenue Generated</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-foreground font-mono">10K+</p>
          <p class="text-sm text-foreground-muted mt-1">Leads Captured</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-foreground font-mono">340%</p>
          <p class="text-sm text-foreground-muted mt-1">Avg ROI</p>
        </div>
      </div>
    </Hero>
  </div>

  {/* ================================================================
      FEATURES — Light section
      ================================================================ */}
  <section id="features" class="py-[var(--space-section-lg)] bg-background">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Everything you need</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-foreground">Scale without the headcount</h2>
        <p class="mt-4 text-lg text-foreground-muted max-w-2xl mx-auto">
          Three powerful systems working together to turn strangers into customers, on autopilot.
          No code. No complexity. Just revenue.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {/* Feature 1 */}
        <div class="group rounded-xl border border-border bg-card p-8 transition-all hover:border-border-strong hover:shadow-lg">
          <div class="h-12 w-12 rounded-lg bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center mb-6">
            <svg class="h-6 w-6 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground mb-3">Capture Every Lead</h3>
          <p class="text-foreground-muted leading-relaxed">
            Smart forms that adapt in real-time. Qualify prospects instantly and route
            them to the right offer — before they bounce.
          </p>
        </div>

        {/* Feature 2 */}
        <div class="group rounded-xl border border-border bg-card p-8 transition-all hover:border-border-strong hover:shadow-lg">
          <div class="h-12 w-12 rounded-lg bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center mb-6">
            <svg class="h-6 w-6 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground mb-3">Automate the Follow-Up</h3>
          <p class="text-foreground-muted leading-relaxed">
            AI-powered sequences that nurture leads with the right message at the right
            time. No more manual chasing or missed opportunities.
          </p>
        </div>

        {/* Feature 3 */}
        <div class="group rounded-xl border border-border bg-card p-8 transition-all hover:border-border-strong hover:shadow-lg">
          <div class="h-12 w-12 rounded-lg bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center mb-6">
            <svg class="h-6 w-6 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-foreground mb-3">Close While You Sleep</h3>
          <p class="text-foreground-muted leading-relaxed">
            Automated booking, payment collection, and onboarding. Wake up to new
            customers every morning — without lifting a finger.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ================================================================
      TESTIMONIAL — Dark invert section
      ================================================================ */}
  <section class="invert-section bg-background py-[var(--space-section-lg)]">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <div class="flex justify-center mb-8">
        <div class="flex -space-x-1">
          {[1,2,3,4,5].map(() => (
            <svg class="h-5 w-5 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
      </div>
      <blockquote>
        <p class="text-2xl md:text-4xl font-display font-bold tracking-tight text-foreground leading-tight">
          "We plugged this into our agency and went from $40K to $180K MRR in 90 days.
          The ROI is absolutely insane."
        </p>
        <footer class="mt-8 flex flex-col items-center gap-3">
          <div class="h-12 w-12 rounded-full bg-secondary flex items-center justify-center text-foreground-muted font-semibold text-sm">
            JM
          </div>
          <div>
            <p class="font-semibold text-foreground">Jake Morrison</p>
            <p class="text-sm text-foreground-muted">CEO, Morrison Digital</p>
          </div>
        </footer>
      </blockquote>
    </div>
  </section>

  {/* ================================================================
      HOW IT WORKS — Light section
      ================================================================ */}
  <section class="py-[var(--space-section-lg)] bg-background">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Simple setup</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-foreground">Live in 15 minutes, not 15 weeks</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="h-14 w-14 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center mx-auto mb-6">
            <span class="text-lg font-bold font-mono text-brand-600 dark:text-brand-400">01</span>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">Connect your accounts</h3>
          <p class="text-foreground-muted">
            Link your ad platforms, CRM, and payment processor. One-click integrations — no developer needed.
          </p>
        </div>
        <div class="text-center">
          <div class="h-14 w-14 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center mx-auto mb-6">
            <span class="text-lg font-bold font-mono text-brand-600 dark:text-brand-400">02</span>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">Choose your funnel</h3>
          <p class="text-foreground-muted">
            Pick from proven templates or build custom. AI optimizes your copy, design, and flow automatically.
          </p>
        </div>
        <div class="text-center">
          <div class="h-14 w-14 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center mx-auto mb-6">
            <span class="text-lg font-bold font-mono text-brand-600 dark:text-brand-400">03</span>
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">Watch the revenue flow</h3>
          <p class="text-foreground-muted">
            Go live and let the system work. Track every lead, conversion, and dollar from your dashboard.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ================================================================
      PRICING
      ================================================================ */}
  <section id="pricing" class="py-[var(--space-section-lg)] bg-background-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold text-brand-600 uppercase tracking-wider mb-3">Pricing</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-foreground">Simple pricing, serious ROI</h2>
        <p class="mt-4 text-lg text-foreground-muted max-w-2xl mx-auto">
          Every plan pays for itself. Pick the one that matches your pipeline.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        {/* Starter */}
        <div class="rounded-xl border border-border bg-card p-8">
          <p class="text-sm font-semibold text-foreground-muted uppercase tracking-wider">Starter</p>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-bold font-mono text-foreground">$0</span>
            <span class="text-foreground-muted">/mo</span>
          </div>
          <p class="mt-3 text-sm text-foreground-muted">For solo operators testing the waters.</p>
          <ul class="mt-8 space-y-3 text-sm text-foreground-secondary">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              1 funnel, 100 leads/mo
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Basic email sequences
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Community support
            </li>
          </ul>
          <div class="mt-8">
            <Button variant="secondary" fullWidth href="#get-started">Get Started Free</Button>
          </div>
        </div>

        {/* Pro — featured */}
        <div class="rounded-xl border-2 border-brand-500 bg-card p-8 relative shadow-lg">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <Badge variant="brand" pill>Most Popular</Badge>
          </div>
          <p class="text-sm font-semibold text-brand-600 dark:text-brand-400 uppercase tracking-wider">Pro</p>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-bold font-mono text-foreground">$97</span>
            <span class="text-foreground-muted">/mo</span>
          </div>
          <p class="mt-3 text-sm text-foreground-muted">For growing teams ready to scale revenue.</p>
          <ul class="mt-8 space-y-3 text-sm text-foreground-secondary">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Unlimited funnels & leads
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              AI-powered sequences
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              CRM & payment integrations
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Priority support
            </li>
          </ul>
          <div class="mt-8">
            <Button fullWidth href="#get-started">Start 14-Day Trial</Button>
          </div>
        </div>

        {/* Scale */}
        <div class="rounded-xl border border-border bg-card p-8">
          <p class="text-sm font-semibold text-foreground-muted uppercase tracking-wider">Scale</p>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-bold font-mono text-foreground">$297</span>
            <span class="text-foreground-muted">/mo</span>
          </div>
          <p class="mt-3 text-sm text-foreground-muted">For agencies and teams running multiple brands.</p>
          <ul class="mt-8 space-y-3 text-sm text-foreground-secondary">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Everything in Pro
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              White-label branding
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Multi-workspace management
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-brand-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Dedicated account manager
            </li>
          </ul>
          <div class="mt-8">
            <Button variant="secondary" fullWidth href="/contact">Contact Sales</Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ================================================================
      CTA — Dark section
      ================================================================ */}
  <section id="get-started" class="invert-section bg-background py-[var(--space-section-xl)] relative overflow-hidden">
    {/* Ambient glow */}
    <div class="absolute inset-0 bg-grid-pattern pointer-events-none [mask-image:linear-gradient(to_bottom,white_60%,transparent)]" aria-hidden="true"></div>

    <div class="mx-auto max-w-3xl px-6 text-center relative z-10">
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-foreground">
        Ready to turn your traffic into revenue?
      </h2>
      <p class="mt-6 text-lg text-foreground-muted max-w-xl mx-auto">
        Join 10,000+ businesses already growing on autopilot.
        Start free, upgrade when you're ready.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg">Get Started Free</Button>
        <Button size="lg" variant="outline">Book a Demo</Button>
      </div>
      <p class="mt-6 text-xs text-foreground-muted/60">No credit card required. Free plan available forever.</p>
    </div>
  </section>

  <Footer
    slot="footer"
    layout="stacked"
    showCopyright
    tagline="AI-powered funnels that turn clicks into customers."
    legalLinks={[
      { label: 'Privacy', href: '/privacy' },
      { label: 'Terms', href: '/terms' },
    ]}
  />
</BaseLayout>
