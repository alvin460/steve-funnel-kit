  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- SP5. VIDEO TESTIMONIAL — last-chance proof                        -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="bg-background border-y border-border py-[var(--space-section-sm)]">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <p class="text-xs font-mono uppercase tracking-wider text-foreground-muted mb-6">
        See it in action
      </p>
      <!-- Video placeholder — replace with real video embed -->
      <div class="relative aspect-video rounded-2xl bg-secondary border border-border overflow-hidden group cursor-pointer">
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="flex h-16 w-16 items-center justify-center rounded-full bg-brand-300 text-[var(--gray-950)] shadow-lg group-hover:scale-110 transition-transform">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="9.5,7.5 16.5,12 9.5,16.5"></polygon></svg>
          </div>
        </div>
