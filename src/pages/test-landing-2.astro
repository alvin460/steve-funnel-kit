  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- DIALOG                                                            -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <Dialog id="playbook-dialog" title="Get the LinkedIn Sell-by-Chat Playbook" size="md">
    <p class="text-sm text-foreground-muted mb-4">
      14 pages of DM openers, follow-up sequences, and objection handlers from seven-figure closers. Free. We'll send it right over.
    </p>
    <LeadCaptureForm
      client:load
      formTags={formTags}
      submitLabel="Send Me The Playbook"
      termsHtml={termsHtml}
    />
  </Dialog>

  <!-- FLOATING CTA BAR -->
  <div class="floating-cta" id="floating-cta">
