  <Footer slot="footer" layout="simple" background="secondary" showCopyright={false} />
</BaseLayout>

<style>
  /* ── CHANGE 6: LinkedIn mockup animations ── */
  .dm-pulse {
    animation: dmPulse 3s ease-in-out infinite;
  }
  @keyframes dmPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  /* ── CHANGE 2b: Playbook CTA lime gradient ── */
  .playbook-gradient {
    background-image: radial-gradient(ellipse 60% 50% at 50% 40%, oklch(from var(--brand-300) l c h / 0.07) 0%, transparent 70%);
  }

  /* ── Pricing card (annual) — dark bg with lime gradient ── */
  .pricing-card-annual {
    background:
      radial-gradient(ellipse 80% 60% at 85% 20%, rgba(206, 241, 123, 0.12) 0%, transparent 70%),
      linear-gradient(180deg, #1a1a1a 0%, #0d0d0d 100%);
  }

  .pricing-cta {
    box-shadow: inset 0px 2px 0px rgba(255, 255, 255, 0.08);
  }

  /* ── Floating CTA bar ── */
  .floating-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 1rem 0;
    background: oklch(from var(--background) l c h / 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--border);
    transform: translateY(150%);
    transition: transform 0.3s ease;
  }

  .floating-cta.visible {
    transform: translateY(0);
  }

  /* ── Mobile dialog full-screen ── */
  @media (max-width: 640px) {
    :global(#playbook-dialog [data-dialog-panel]) {
      max-width: 100% !important;
      border-radius: 0;
      min-height: 100vh;
      max-height: none;
    }
  }

  @supports (-webkit-touch-callout: none) {
    :global(#playbook-dialog) input,
    :global(#playbook-dialog) textarea,
    :global(#playbook-dialog) select {
      font-size: 16px !important;
    }
  }
</style>

<script>
  // Dialog triggers
  document.querySelectorAll('[data-open-dialog]').forEach((el) => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const id = el.getAttribute('data-open-dialog');
      if (id && (window as any).openDialog) (window as any).openDialog(id);
    });
  });

  // Floating CTA scroll logic
  const floatingCta = document.getElementById('floating-cta');
  if (floatingCta) {
    const showThreshold = window.innerWidth < 768 ? 450 : 768;
    let visible = false;

    function update() {
      const scrollY = window.scrollY;
      const finalCta = document.getElementById('final-cta');
      const docHeight = document.documentElement.scrollHeight;
      const viewportHeight = window.innerHeight;
      const nearBottom = scrollY + viewportHeight > docHeight - 200;

      let hideNearFinalCta = false;
      if (finalCta) {
        const rect = finalCta.getBoundingClientRect();
        hideNearFinalCta = rect.top < viewportHeight + 200;
      }

      if (scrollY > showThreshold && !nearBottom && !hideNearFinalCta) {
        if (!visible) { floatingCta.classList.add('visible'); visible = true; }
      } else {
        if (visible) { floatingCta.classList.remove('visible'); visible = false; }
      }
    }

    window.addEventListener('scroll', update, { passive: true });
  }
</script>
