---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import { Hero } from '@/components/hero';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Accordion from '@/components/ui/overlay/Accordion/Accordion.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import Dialog from '@/components/ui/overlay/Dialog/Dialog.astro';
import LeadCaptureForm from '../components/forms/LeadCaptureForm.tsx';

const formTags = ['linkninja_lead', 'homepage_playbook'];
const termsHtml = `<p>By providing my information, I agree to receive communications from LinkNinja and accept the <a href="/privacy/">Privacy Policy</a>. Unsubscribe anytime.</p>`;

/* ── Hero rotating words ── */
const rotatingWords = ['LinkedIn DMs', 'Sales Navigator', 'Lead Lists', 'Cold Outreach', 'Pipeline Deals'];

/* ── What you get ── */
const corePowers = [
  {
    icon: 'inbox',
    title: 'AI-Classified Inbox',
    description: 'Every LinkedIn conversation gets auto-classified. Hot, warm, cold, ghosted. You see your pipeline at a glance — not a wall of unread messages.',
  },
  {
    icon: 'zap',
    title: 'Ghost Detection',
    description: 'Know exactly who vanished mid-conversation. LinkNinja flags ghosts automatically so you can follow up or move on — no guessing.',
  },
  {
    icon: 'search',
    title: 'Sales Navigator Sync',
    description: 'Import saved searches, lead lists, and profile data directly. Your Sales Nav investment finally feeds a real pipeline instead of a spreadsheet.',
  },
  {
    icon: 'users',
    title: 'GHL Pipeline Sync',
    description: 'Two-way sync with GoHighLevel. Contacts, tags, stages, and conversation history flow both directions. One source of truth.',
  },
  {
    icon: 'edit',
    title: 'Smart Snippets',
    description: 'Templated messages with personalization tokens. Write once, insert everywhere. Sound human at scale without copy-pasting from a Google Doc.',
  },
  {
    icon: 'star',
    title: 'AI Daily Brief',
    description: 'Wake up to a summary of who replied, who went cold, and who needs attention today. Your AI assistant that actually reads the room.',
  },
  {
    icon: 'globe',
    title: 'Post Engagement Tool',
    description: 'Track who engaged with your posts and turn commenters into conversations. Content-to-DM pipeline on autopilot.',
  },
  {
    icon: 'layers',
    title: 'Semantic Search',
    description: 'Search your conversations by meaning, not just keywords. Find "that guy who mentioned Q3 budget" in seconds.',
  },
];

/* ── Capability tabs ── */
const capabilities = [
  {
    id: 'pipeline',
    label: 'Pipeline',
    icon: 'inbox',
    title: 'Your DMs become a real pipeline.',
    description: 'Every conversation gets a stage. Every stage syncs to your CRM. You see exactly where every deal stands — and what needs to happen next.',
    benefits: [
      'Auto-classify conversations: Hot / Warm / Cold / Ghosted',
      'Custom pipeline stages that match how you actually sell',
      'Drag-and-drop stage updates that sync to GHL in real time',
      'Filter by "Needs Reply" and "Follow-Up Due" to prioritize your day',
    ],
  },
  {
    id: 'intelligence',
    label: 'AI Intelligence',
    icon: 'star',
    title: 'AI that reads the room for you.',
    description: 'LinkNinja\'s AI processes every conversation, scores every lead, and tells you exactly who deserves your attention — before you even open the inbox.',
    benefits: [
      'Lead scoring based on engagement, profile fit, and conversation signals',
      'Chat scoring: know if a thread is heating up or going cold',
      'AI-generated openers based on the prospect\'s profile and activity',
      'Daily brief summarizing replies, ghosts, and priority actions',
    ],
  },
  {
    id: 'sync',
    label: 'CRM Sync',
    icon: 'layers',
    title: 'Two-way sync. Zero duct tape.',
    description: 'Your LinkedIn conversations and your CRM finally speak the same language. Contacts, tags, stages, and notes flow both directions automatically.',
    benefits: [
      'GoHighLevel two-way sync (contacts, tags, pipeline stages)',
      'Sales Navigator lead list importing',
      'Conversation history attached to every CRM contact',
      'Auto-tag contacts based on conversation stage and AI classification',
    ],
  },
];

/* ── FAQ ── */
const faqItems = [
  {
    title: 'Is this an automation tool? Will it send messages for me?',
    content: "No. LinkNinja doesn't send messages, scrape data, or do anything that violates LinkedIn's terms. It's an intelligence and pipeline layer that sits on top of your existing LinkedIn account. You send every message yourself. We just make sure nothing falls through the cracks.",
  },
  {
    title: 'Will my LinkedIn account get restricted?',
    content: "No scraping. No bots. No automated messaging. LinkNinja syncs your conversations — it doesn't interfere with them. Your messages are encrypted and only accessible to you.",
  },
  {
    title: 'What CRM does it integrate with?',
    content: 'GoHighLevel (GHL) is the primary integration. Two-way sync for contacts, tags, pipeline stages, and conversation data. More CRM integrations are on the roadmap.',
  },
  {
    title: 'Do I need Sales Navigator?',
    content: "No. LinkNinja works with any LinkedIn account. Sales Navigator integration unlocks lead list importing and saved search syncing, but the core pipeline, classification, and inbox features work without it.",
  },
  {
    title: 'How fast does it sync?',
    content: 'Conversations sync in near real-time. New messages, replies, and connection requests appear in your LinkNinja pipeline within minutes. CRM sync is continuous.',
  },
  {
    title: 'Can I cancel anytime?',
    content: 'Monthly plans cancel anytime. Annual plans are billed upfront for the year. No contracts, no hidden fees, no cancellation hoops.',
  },
  {
    title: 'What about the SevenFigureCreators.com program?',
    content: 'Every LinkNinja subscription includes access to the sevenfigurecreators.com community — training, frameworks, and a network of closers who sell by chat. The playbook we give away free is just the start.',
  },
];

/* ── Pricing features ── */
const planFeatures = [
  'AI-Classified Inbox (Hot / Warm / Cold / Ghosted)',
  'Ghost Detection & Follow-Up Alerts',
  'Custom Pipeline Stages + Drag-and-Drop',
  'GoHighLevel Two-Way Sync',
  'Sales Navigator Lead List Import',
  'Smart Snippets with Personalization Tokens',
  'AI Lead Scoring + Chat Scoring',
  'AI Daily Brief & Priority Recommendations',
  'AI Openers for Cold Leads',
  'Post Engagement Tracker',
  'Semantic Search Across All Conversations',
  'SevenFigureCreators.com Community Access',
];
---

<BaseLayout
  title="LinkNinja — The #1 Sell-by-Chat System for LinkedIn"
  description="Turn LinkedIn messenger chaos into a clean, trackable deal flow. AI-classified inbox, ghost detection, pipeline stages, and CRM sync. Built by real DM closers."
>
  <Header
    slot="header"
    position="fixed"
    size="lg"
    scrollReveal
    showCta
    cta={{ label: 'Get FREE Playbook', href: '#playbook' }}
    extraNav={[
      { label: 'Features', href: '#features' },
      { label: 'Pricing', href: '#pricing' },
    ]}
  />

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- 1. HERO -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <Hero layout="centered" size="lg" showGrid>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="zap" size="xs" />
      LinkNinja 2.0 is here
    </Badge>

    <Fragment slot="title">
      The #1 <span class="text-brand-300">sell-by-chat</span><br class="hidden md:block" />
      system for LinkedIn
    </Fragment>

    <p slot="description">
      Be a Ninja in the DMs. Turn LinkedIn messenger chaos into a clean, trackable deal flow.
    </p>

    <div slot="actions">
      <Button size="lg" data-open-dialog="playbook-dialog">
        Get FREE LinkedIn Playbook
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="#features">
        See How It Works
      </Button>
    </div>

    <!-- Rotating context -->
    <div class="mt-6 flex items-center justify-center gap-2 text-sm text-foreground-muted" aria-hidden="true">
      <span class="inline-flex items-center gap-1.5">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-brand-300 animate-pulse"></span>
        <span class="rotating-words">
          {rotatingWords.map((word, i) => (
            <span class="rotating-word" style={`animation-delay: ${i * 2.5}s`}>{word}</span>
          ))}
        </span>
      </span>
    </div>
  </Hero>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- 2. FEATURE CAPSULES -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="bg-background-secondary border-y border-border py-[var(--space-section-sm)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-1 gap-[var(--space-content-gap)] md:grid-cols-3">
        <Card variant="elevated" padding="md" hover>
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-300/10">
              <Icon name="inbox" size="md" class="text-brand-300" />
            </div>
            <div>
              <p class="text-sm font-bold uppercase tracking-wider text-foreground font-mono">Auto-Sync</p>
              <p class="text-sm text-foreground-muted">Your LinkedIn DMs, live in your CRM</p>
            </div>
          </div>
        </Card>
        <Card variant="elevated" padding="md" hover>
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-300/10">
              <Icon name="trending-up" size="md" class="text-brand-300" />
            </div>
            <div>
              <p class="text-sm font-bold uppercase tracking-wider text-foreground font-mono">AI Pipeline</p>
              <p class="text-sm text-foreground-muted">Every chat classified and scored</p>
            </div>
          </div>
        </Card>
        <Card variant="elevated" padding="md" hover>
          <div class="flex items-center gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-brand-300/10">
              <Icon name="eye" size="md" class="text-brand-300" />
            </div>
            <div>
              <p class="text-sm font-bold uppercase tracking-wider text-foreground font-mono">Ghost Detection</p>
              <p class="text-sm text-foreground-muted">Know who vanished, instantly</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- 3. PROBLEM — "LinkedIn's inbox is a nightmare" -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="bg-background py-[var(--space-section-md)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl mb-[var(--space-section-gap)]">
        <p class="text-sm font-medium uppercase tracking-wider text-foreground-muted font-mono mb-[var(--space-stack-sm)]">The Problem</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          LinkedIn's inbox is a nightmare if you're actually trying to use it for sales.
        </h2>
      </div>

      <!-- Chat mockup grid -->
      <div class="grid gap-[var(--space-content-gap)] md:grid-cols-2 lg:grid-cols-3 mb-[var(--space-section-gap)]">
        <Card variant="outline" padding="lg">
          <div class="flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="h-8 w-8 rounded-full bg-background-secondary"></div>
                <div>
                  <p class="text-sm font-semibold text-foreground">John Smith</p>
                  <p class="text-xs text-foreground-muted">3 days ago</p>
                </div>
              </div>
              <span class="text-lg" aria-hidden="true">👻</span>
            </div>
            <p class="text-sm text-foreground-muted italic">"Did I already message that guy?"</p>
            <span class="inline-block w-fit text-xs bg-[var(--error)]/10 text-[var(--error)] px-2 py-0.5 rounded-full">Unread</span>
          </div>
        </Card>

        <Card variant="outline" padding="lg">
          <div class="flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="h-8 w-8 rounded-full bg-background-secondary"></div>
                <div>
                  <p class="text-sm font-semibold text-foreground">Rebecca Moore</p>
                  <p class="text-xs text-foreground-muted">Last week</p>
                </div>
              </div>
              <span class="text-lg" aria-hidden="true">👻</span>
            </div>
            <p class="text-sm text-foreground-muted italic">No tagging. No filters that matter.</p>
            <p class="text-xs text-foreground-muted">No way to track who's hot, who needs follow-up, or who ghosted you for 3 days.</p>
          </div>
        </Card>

        <Card variant="outline" padding="lg">
          <div class="flex flex-col gap-3">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="h-8 w-8 rounded-full bg-background-secondary"></div>
                <div>
                  <p class="text-sm font-semibold text-foreground">Steve Butler</p>
                  <p class="text-xs text-foreground-muted">2 weeks ago</p>
                </div>
              </div>
              <span class="text-lg" aria-hidden="true">👻</span>
            </div>
            <p class="text-sm text-foreground-muted italic">You scroll. You forget. You drop leads.</p>
            <p class="text-xs text-foreground-muted">"Or was it someone else who kind of looked the same?"</p>
          </div>
        </Card>
      </div>

      <!-- Stats callout -->
      <div class="mx-auto max-w-2xl text-center">
        <div class="inline-flex items-center gap-4 rounded-xl border border-border bg-background-secondary px-8 py-5">
          <p class="text-4xl font-bold font-display tracking-tight text-foreground">79%</p>
          <div class="text-left">
            <p class="text-sm font-semibold text-foreground">of convos go cold</p>
            <p class="text-xs text-foreground-muted">This is how deals die — quietly. In the inbox.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- 4. "CLOSERS. NOT SPAMMERS." -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
        Closers. Not Spammers.
      </h2>

      <div class="prose max-w-none mt-[var(--space-stack-lg)]">
        <p>
          You're not trying to automate and blast. You're building relationships.
          Selling by chat. Having real conversations with real decision-makers.
        </p>
        <p>But LinkedIn's native tools weren't built for that.</p>
        <p>Meanwhile:</p>
      </div>

      <ul class="space-y-3 my-[var(--space-stack-lg)]">
        <li class="flex items-start gap-3 text-foreground-secondary">
          <Icon name="alert-circle" size="sm" class="text-warning mt-0.5 shrink-0" />
          <span>Your notes are scattered across Notion, Airtable, and your brain.</span>
        </li>
        <li class="flex items-start gap-3 text-foreground-secondary">
          <Icon name="alert-circle" size="sm" class="text-warning mt-0.5 shrink-0" />
          <span>Follow-ups fall through the cracks because there's no system.</span>
        </li>
        <li class="flex items-start gap-3 text-foreground-secondary">
          <Icon name="alert-circle" size="sm" class="text-warning mt-0.5 shrink-0" />
          <span>Leads stuck in limbo with zero context on where the conversation left off.</span>
        </li>
        <li class="flex items-start gap-3 text-foreground-secondary">
          <Icon name="alert-circle" size="sm" class="text-warning mt-0.5 shrink-0" />
          <span>You're juggling 30+ conversations a day and that "limbo" is turning into <strong class="text-foreground">lost revenue.</strong></span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- 5. SOLUTION -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section id="features" class="bg-background py-[var(--space-section-md)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl mb-[var(--space-section-gap)]">
        <p class="text-sm font-medium uppercase tracking-wider text-foreground-muted font-mono mb-[var(--space-stack-sm)]">The Solution</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground mb-[var(--space-heading-gap)]">
          Built by closers who sell by chat every day.
        </h2>
        <p class="text-foreground-secondary leading-relaxed text-lg">
          LinkNinja gives you an intelligence layer on top of LinkedIn — so you can run DMs
          like a real sales operation. Not a guessing game.
        </p>
      </div>

      <div class="grid gap-[var(--space-content-gap)] md:grid-cols-2 lg:grid-cols-4">
        {corePowers.map((p) => (
          <Card variant="default" padding="lg" hover>
            <div class="flex flex-col gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-brand-300/10">
                <Icon name={p.icon} size="md" class="text-brand-300" />
              </div>
              <h3 class="text-sm font-bold text-foreground">{p.title}</h3>
              <p class="text-xs text-foreground-muted leading-relaxed">{p.description}</p>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- 6. PLAYBOOK CTA (MID-PAGE) -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <CTA id="playbook" variant="default" size="sm" maxWidth="lg" class="bg-background-secondary border-y border-border">
    <Badge slot="logo" variant="brand" pill>
      <Icon name="book" size="xs" />
      Free Download
    </Badge>

    <h2 slot="heading">
      Get The FREE LinkedIn Sell-by-Chat Playbook
    </h2>

    <p slot="description">
      The exact playbook we've used to close millions in deals on LinkedIn — and teach inside
      sevenfigurecreators.com. Yours free. Next steps to join LinkNinja are inside.
    </p>

    <Fragment slot="actions">
      <Button size="lg" data-open-dialog="playbook-dialog">
        Get FREE Playbook
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </CTA>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- 7. CAPABILITIES (TABS) -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="bg-background py-[var(--space-section-md)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl text-center mb-[var(--space-section-gap)]">
        <p class="text-sm font-medium uppercase tracking-wider text-foreground-muted font-mono mb-[var(--space-stack-sm)]">Deep Dive</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          How LinkNinja transforms your LinkedIn outreach.
        </h2>
      </div>

      <!-- Tab buttons -->
      <div class="flex justify-center gap-2 mb-[var(--space-section-gap)]" role="tablist">
        {capabilities.map((cap, i) => (
          <button
            type="button"
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${cap.id}`}
            class:list={[
              'capability-tab inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-medium transition-all duration-150 ease-out',
              i === 0
                ? 'bg-brand-300 text-[var(--gray-950)] shadow-[var(--shadow-button-glow)]'
                : 'border border-border bg-transparent text-foreground-muted hover:bg-secondary hover:border-border-strong hover:text-foreground',
            ]}
            data-tab={cap.id}
          >
            <Icon name={cap.icon} size="xs" />
            {cap.label}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      {capabilities.map((cap, i) => (
        <div
          id={`panel-${cap.id}`}
          role="tabpanel"
          class:list={['capability-panel', i !== 0 && 'hidden']}
          data-panel={cap.id}
        >
          <div class="grid gap-[var(--space-section-gap)] md:grid-cols-2 items-center">
            <div>
              <h3 class="font-display text-2xl font-bold tracking-tight text-foreground mb-[var(--space-heading-gap)]">
                {cap.title}
              </h3>
              <p class="text-foreground-secondary leading-relaxed">{cap.description}</p>
              <ul class="mt-[var(--space-stack-lg)] space-y-3">
                {cap.benefits.map((b) => (
                  <li class="flex items-start gap-3 text-sm text-foreground-secondary">
                    <Icon name="check" size="xs" class="text-brand-300 mt-0.5 shrink-0" />
                    {b}
                  </li>
                ))}
              </ul>
            </div>
            <Card variant="outline" padding="lg" class="aspect-video flex items-center justify-center">
              <div class="text-center">
                <Icon name="monitor" size="xl" class="text-foreground-subtle opacity-30 mx-auto" />
                <p class="text-sm text-foreground-muted mt-2">Product Preview</p>
              </div>
            </Card>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════════ -->
  <!-- 8. MCP — CONNECT YOUR AI -->
  <!-- ════════════════════════════════════════════════════════════════ -->
  <section class="bg-background-secondary py-[var(--space-section-md)]">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-3xl text-center mb-[var(--space-section-gap)]">
        <Badge variant="brand" pill class="mb-[var(--space-stack-sm)]">
          <Icon name="code" size="xs" />
          MCP Server
        </Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight text-foreground">
          Connect your AI.
        </h2>
        <p class="mt-4 text-lg text-foreground-muted">
          Give any AI full context on your conversations, leads, and deals.
          LinkNinja ships with a built-in MCP server that works with every major AI platform.
        </p>
      </div>

      <!-- Platform grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-[var(--space-content-gap)] max-w-3xl mx-auto mb-[var(--space-section-gap)]">
        <!-- Claude.ai -->
        <Card hover>
          <div class="flex flex-col items-center gap-3 text-center">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[#D97757]/10">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="#D97757" aria-hidden="true">
                <path d="M12 2C12.5 6.5 17.5 11.5 22 12C17.5 12.5 12.5 17.5 12 22C11.5 17.5 6.5 12.5 2 12C6.5 11.5 11.5 6.5 12 2Z"/>
              </svg>
            </div>
            <p class="text-sm font-semibold text-foreground">Claude.ai</p>
            <p class="text-xs text-foreground-muted">Web app</p>
          </div>
        </Card>

        <!-- ChatGPT -->
        <Card hover>
          <div class="flex flex-col items-center gap-3 text-center">
            <div class="flex h-11 w-11 items-center justify-center rounded-full bg-[#10A37F]/10">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="#10A37F" aria-hidden="true">
